#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys
            /// Row 0
            = <&key_physical_attrs 100 100    0   0    0 0 0> // LK1
            , <&key_physical_attrs 100 100  100   0    0 0 0>
            , <&key_physical_attrs 100 100  200   0    0 0 0>
            , <&key_physical_attrs 100 100  300   0    0 0 0>
            , <&key_physical_attrs 100 100  400   0    0 0 0>
            , <&key_physical_attrs 100 100  500   0    0 0 0>
            , <&key_physical_attrs 100 100  600   0    0 0 0> // LK7
            // Row 1
            , <&key_physical_attrs 100 100    0 100    0 0 0> // LK8
            , <&key_physical_attrs 100 100  100 100    0 0 0>
            , <&key_physical_attrs 100 100  200 100    0 0 0>
            , <&key_physical_attrs 100 100  300 100    0 0 0>
            , <&key_physical_attrs 100 100  400 100    0 0 0>
            , <&key_physical_attrs 100 100  500 100    0 0 0>
            , <&key_physical_attrs 100 100  600 100    0 0 0> // LK14
            // Row 2
            , <&key_physical_attrs 100 100    0 200    0 0 0> // LK15
            , <&key_physical_attrs 100 100  100 200    0 0 0>
            , <&key_physical_attrs 100 100  200 200    0 0 0>
            , <&key_physical_attrs 100 100  300 200    0 0 0>
            , <&key_physical_attrs 100 100  400 200    0 0 0>
            , <&key_physical_attrs 100 100  500 200    0 0 0>
            , <&key_physical_attrs 100 100  600 200    0 0 0> // LK21
            // Row 3
            , <&key_physical_attrs 100 100    0 300    0 0 0> // LK22
            , <&key_physical_attrs 100 100  100 300    0 0 0>
            , <&key_physical_attrs 100 100  200 300    0 0 0>
            , <&key_physical_attrs 100 100  300 300    0 0 0>
            , <&key_physical_attrs 100 100  400 300    0 0 0>
            , <&key_physical_attrs 100 100  500 300    0 0 0> // LK27

            // --- RIGHT HALF (Rows 0-3) - 8u Gap starts at 1400 ---
            // Row 0
            , <&key_physical_attrs 100 100 1400   0    0 0 0> // RK7
            , <&key_physical_attrs 100 100 1500   0    0 0 0>
            , <&key_physical_attrs 100 100 1600   0    0 0 0>
            , <&key_physical_attrs 100 100 1700   0    0 0 0>
            , <&key_physical_attrs 100 100 1800   0    0 0 0>
            , <&key_physical_attrs 100 100 1900   0    0 0 0>
            , <&key_physical_attrs 100 100 2000   0    0 0 0> // RK1
            // Row 1
            , <&key_physical_attrs 100 100 1400 100    0 0 0> // RK14
            , <&key_physical_attrs 100 100 1500 100    0 0 0>
            , <&key_physical_attrs 100 100 1600 100    0 0 0>
            , <&key_physical_attrs 100 100 1700 100    0 0 0>
            , <&key_physical_attrs 100 100 1800 100    0 0 0>
            , <&key_physical_attrs 100 100 1900 100    0 0 0>
            , <&key_physical_attrs 100 100 2000 100    0 0 0> // RK8
            // Row 2
            , <&key_physical_attrs 100 100 1400 200    0 0 0> // RK21
            , <&key_physical_attrs 100 100 1500 200    0 0 0>
            , <&key_physical_attrs 100 100 1600 200    0 0 0>
            , <&key_physical_attrs 100 100 1700 200    0 0 0>
            , <&key_physical_attrs 100 100 1800 200    0 0 0>
            , <&key_physical_attrs 100 100 1900 200    0 0 0>
            , <&key_physical_attrs 100 100 2000 200    0 0 0> // RK15
            // Row 3
            , <&key_physical_attrs 100 100 1500 300    0 0 0> // RK27
            , <&key_physical_attrs 100 100 1600 300    0 0 0>
            , <&key_physical_attrs 100 100 1700 300    0 0 0>
            , <&key_physical_attrs 100 100 1800 300    0 0 0>
            , <&key_physical_attrs 100 100 1900 300    0 0 0>
            , <&key_physical_attrs 100 100 2000 300    0 0 0> // RK22

            // --- ROW 3 (LK22-27 and RK27-22) ---
            = <&key_physical_attrs 100 100    0 300    0 0 0> 
            , <&key_physical_attrs 100 100  100 300    0 0 0>
            , <&key_physical_attrs 100 100  200 300    0 0 0>
            , <&key_physical_attrs 100 100  300 300    0 0 0>
            , <&key_physical_attrs 100 100  400 300    0 0 0>
            , <&key_physical_attrs 100 100  500 300    0 0 0>
            , <&key_physical_attrs 100 100 1500 300    0 0 0> 
            , <&key_physical_attrs 100 100 1600 300    0 0 0>
            , <&key_physical_attrs 100 100 1700 300    0 0 0>
            , <&key_physical_attrs 100 100 1800 300    0 0 0>
            , <&key_physical_attrs 100 100 1900 300    0 0 0>
            , <&key_physical_attrs 100 100 2000 300    0 0 0>

            // --- ROW 4 (LK28-29 and RK29-28) - REVERTED TO FLAT ---
            // Positioned at Y=400, no rotation.
            , <&key_physical_attrs 100 100  200 400    0 0 0> // LK28 (Pivot Point L)
            , <&key_physical_attrs 100 100  300 400    0 0 0> // LK29
            , <&key_physical_attrs 100 100 1700 400    0 0 0> // RK29
            , <&key_physical_attrs 100 100 1800 400    0 0 0> // RK28 (Pivot Point R)

            
// --- ROW 5 (LK30-31 / RK31-30) ---
            , <&key_physical_attrs 100 100  400 500 2300 600 700> // LK30
            , <&key_physical_attrs 100 100  500 500 2300 600 700> // LK31
            , <&key_physical_attrs 100 100 1500 500 (-2300) 1400 700> // RK31
            , <&key_physical_attrs 100 100 1600 500 (-2300) 1400 700> // RK30

            // --- ROW 6 (LK32-33 / RK33-32) ---
            , <&key_physical_attrs 100 100  600 600 2300 600 700> // LK32
            , <&key_physical_attrs 100 100  700 600 2300 600 700> // LK33
            , <&key_physical_attrs 100 100  1300 600 (-2300) 1400 700> // RK33
            , <&key_physical_attrs 100 100  1400 600 (-2300) 1400 700> // RK32

            // --- ROW 7 (LK34-35 / RK35-34) ---
            , <&key_physical_attrs 100 100  600 700 2300 600 700> // LK34
            , <&key_physical_attrs 100 100  700 700 2300 600 700> // LK35
            , <&key_physical_attrs 100 100  1300 700 (-2300) 1400 700> // RK35
            , <&key_physical_attrs 100 100  1400 700 (-2300) 1400 700> // RK34
            ;
    };
};


