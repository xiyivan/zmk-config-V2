#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include "SX_DACTYL_layouts.dtsi"

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
        // Other chosen items
    };
};

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layouts = &dactyl_layout;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <6>;
// | LK1  | LK2  | LK3  | LK4  | LK5  | LK6  | LK7  |   | RK7  | RK6  | RK5  | RK4  | RK3  | RK2  | RK1  |
// | LK8  | LK9  | LK10 | LK11 | LK12 | LK13 | LK14 |   | RK14 | RK13 | RK12 | RK11 | RK10 | RK9  | RK8  |
// | LK15 | LK16 | LK17 | LK18 | LK19 | LK20 | LK21 |   | RK21 | RK20 | RK19 | RK18 | RK17 | RK16 | RK15 |
// | LK22 | LK23 | LK24 | LK25 | LK26 | LK27 |                 | RK27 | RK26 | RK25 | RK24 | RK23 | RK22 |
//               | LK28 | LK29 |                                             | RK29 | RK28 |
//                             | LK30 | LK31 |                 | RK31 | RK30 |
//                                    | LK32 | LK33 |   | RK33 | RK32 |
//                                    | LK34 | LK35 |   | RK35 | RK34 |

        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)    RC(0,13) RC(0,12) RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)    RC(1,13) RC(1,12) RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)    RC(2,13) RC(2,12) RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                     RC(3,12) RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7)
                RC(4,2) RC(4,3)                                                       RC(4,10) RC(4,9)
                                RC(4,4) RC(4,5)                     RC(4,12) RC(4,11)
                                        RC(5,4) RC(5,5)    RC(5,12) RC(5,11)
                                        RC(5,3) RC(5,6)    RC(5,13) RC(5,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&gpio0 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;

    };
};

&dactyl_layout{

	transform = <&default_transform>;

	kscan = <&kscan0>;

};



zephyr_udc0: &usbd { 

    compatible = "nordic,nrf-usbd"; 

    status = "okay"; 

};

